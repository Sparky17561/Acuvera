# ============================================================
# Acuvera — Environment Variables Template
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-very-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────
# Supabase-compatible connection string (psycopg3)
DATABASE_URL=postgresql://acuvera:password@localhost:5432/acuvera_db

# ── Clerk Auth ───────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# For development only — set to true to bypass JWT validation
# THIS MUST NEVER BE true IN PRODUCTION
BYPASS_AUTH=false

# ── GROQ LLM (Optional) ──────────────────────────────────────
GROQ_API_KEY=gsk_...
LLM_ENABLED_DEFAULT=false

# ── Feature Flags (global defaults; overridden per-hospital) ─
VOICE_INPUT_ENABLED=false
ANALYTICS_ADVANCED=true
FHIR_ENABLED=true
PWA_ENABLED=true

# ── Operational Config ───────────────────────────────────────
MAX_CONCURRENT_ALLOCATION_RETRIES=3
# After N rejections, escalate to dept head
MAX_DOCTOR_REJECTIONS=3

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=

# ── Django CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── FHIR Adapter Auth ────────────────────────────────────────
FHIR_BASIC_USERNAME=fhir_user
FHIR_BASIC_PASSWORD=change-me
